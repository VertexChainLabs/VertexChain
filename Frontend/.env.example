# ============================================
# Frontend Environment Configuration
# ============================================

# NEXT_PUBLIC_API_URL (required)
# Base URL for the VertexChain backend API
# This is used by the frontend to make API calls to the backend server
# 
# Development: http://localhost:3000
# Production: https://api.vertexchain.io (or your deployed backend URL)
#
# IMPORTANT: This variable is exposed to the browser (NEXT_PUBLIC_ prefix)
# Do not include sensitive information in this URL
NEXT_PUBLIC_API_URL=http://localhost:3000
