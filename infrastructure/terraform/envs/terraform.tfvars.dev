# ──────────────────────────────────────────────
# Dev environment — minimal footprint, no HA
# ──────────────────────────────────────────────

# --- Core ---
region       = "us-east-1"
environment  = "dev"
project_name = "vertexchain"

# --- Networking (replace with real IDs or set via CI secrets) ---
vpc_id   = "vpc-00000000000000001"
vpc_cidr = "10.0.0.0/16"

private_subnet_ids = ["subnet-00000000000000001", "subnet-00000000000000002"]
public_subnet_ids  = ["subnet-00000000000000003", "subnet-00000000000000004"]

# --- Compute ---
ami_id        = "ami-0c55b159cbfafe1f0"
instance_type = "t3.micro"

# --- RDS ---
db_instance_class    = "db.t3.micro"
backup_retention_days = 1

# --- ElastiCache ---
redis_node_type        = "cache.t3.micro"
redis_num_cache_nodes  = 1

# --- DNS / TLS ---
domain_name     = "dev.vertexchain.io"
api_domain      = "api.dev.vertexchain.io"
certificate_arn = "arn:aws:acm:us-east-1:000000000000:certificate/dev-placeholder"

# --- Tagging ---
cost_center = "engineering"
owner       = "platform-team"
