# ============================================================
# Example variable values — copy to terraform.tfvars.dev/staging/prod
# and fill in real values.  Never commit terraform.tfvars.*
# (they are gitignored); only this example file is tracked.
# ============================================================

# General
environment  = "dev"           # dev | staging | prod
region       = "us-east-1"
project_name = "vertexchain"
domain_name  = "vertexchain.io"
alert_email  = "ops@vertexchain.io"

# Networking
vpc_cidr             = "10.0.0.0/16"
availability_zones   = ["us-east-1a", "us-east-1b"]
public_subnet_cidrs  = ["10.0.1.0/24", "10.0.2.0/24"]
private_subnet_cidrs = ["10.0.11.0/24", "10.0.12.0/24"]

# Tags
cost_center = "engineering"
owner       = "platform-team"

# Compute
ami_id             = "ami-xxxxxxxxxxxxxxxxx"
instance_type      = "t3.medium"
eks_version        = "1.29"
eks_node_instance_type = "t3.small"
eks_desired_size   = 1
eks_min_size       = 1
eks_max_size       = 3

# ASG
asg_min_size     = 1
asg_max_size     = 3
asg_desired_size = 1

# RDS
db_instance_class = "db.t3.micro"

# ElastiCache / Redis
redis_node_type       = "cache.t3.micro"
redis_num_cache_nodes = 1

# Backup
enable_cross_region_backup = false          # set true for staging/prod
backup_retention_days      = 30
