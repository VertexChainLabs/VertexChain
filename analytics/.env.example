# ============================================
# Analytics Dashboard Environment Configuration
# ============================================

# NEXT_PUBLIC_MAPBOX_TOKEN (required)
# Mapbox GL access token for rendering the Gist Heatmap
# Get yours at: https://account.mapbox.com/access-tokens/
# 
# Steps to obtain:
# 1. Create a free Mapbox account at https://account.mapbox.com/
# 2. Navigate to Access tokens page
# 3. Create a new token or use the default public token
# 4. Copy and paste the token here
#
# IMPORTANT: This token is exposed to the browser (NEXT_PUBLIC_ prefix)
# Use a token with restricted scopes for production
NEXT_PUBLIC_MAPBOX_TOKEN=

# NEXT_PUBLIC_API_URL (required for live data)
# Base URL for the VertexChain backend API
# This is used to fetch real gist data for analytics
#
# Development: http://localhost:3000
# Production: https://api.vertexchain.io (or your deployed backend URL)
#
# Leave empty to use mock data (see NEXT_PUBLIC_USE_MOCK)
NEXT_PUBLIC_API_URL=http://localhost:3000

# NEXT_PUBLIC_USE_MOCK (optional)
# Whether to use mock data instead of making real API calls
# Values: true | false
# Default: false (will auto-enable if NEXT_PUBLIC_API_URL is empty)
#
# Set to "true" for development without a running backend
# Set to "false" to fetch real data from the API
NEXT_PUBLIC_USE_MOCK=false

